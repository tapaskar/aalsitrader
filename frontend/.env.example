# Trading Squad Dashboard - Environment Variables

# WebSocket endpoint for real-time updates
# This should be your API Gateway WebSocket endpoint
VITE_WS_URL=wss://your-api.execute-api.ap-south-1.amazonaws.com/prod

# API endpoint for REST calls (trade logging, etc.)
VITE_API_URL=https://your-api.execute-api.ap-south-1.amazonaws.com/prod

# Optional: OpenClaw integration endpoint
VITE_OPENCLAW_URL=http://localhost:18789
