{
  "name": "trading-squad-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:websocket": "esbuild src/websocket.ts --platform=node --target=node20 --bundle --outfile=dist/websocket.js --format=cjs",
    "build:http": "esbuild src/http.ts --platform=node --target=node20 --bundle --outfile=dist/http.js --format=cjs",
    "build:simulator": "esbuild src/simulator.ts --platform=node --target=node20 --bundle --outfile=dist/simulator.js --format=cjs",
    "build:agent-orchestrator": "esbuild src/agents/orchestrator.ts --platform=node --target=node20 --bundle --outfile=dist/agent-orchestrator.js --format=cjs",
    "build:agent-alpha": "esbuild src/agents/alpha.ts --platform=node --target=node20 --bundle --outfile=dist/agent-alpha.js --format=cjs",
    "build:agent-beta": "esbuild src/agents/beta.ts --platform=node --target=node20 --bundle --outfile=dist/agent-beta.js --format=cjs",
    "build:agent-gamma": "esbuild src/agents/gamma.ts --platform=node --target=node20 --bundle --outfile=dist/agent-gamma.js --format=cjs",
    "build:agent-theta": "esbuild src/agents/theta.ts --platform=node --target=node20 --bundle --outfile=dist/agent-theta.js --format=cjs",
    "build:agent-delta": "esbuild src/agents/delta.ts --platform=node --target=node20 --bundle --outfile=dist/agent-delta.js --format=cjs",
    "build:agent-sigma": "esbuild src/agents/sigma.ts --platform=node --target=node20 --bundle --outfile=dist/agent-sigma.js --format=cjs",
    "build:agents": "npm run build:agent-orchestrator && npm run build:agent-alpha && npm run build:agent-beta && npm run build:agent-gamma && npm run build:agent-theta && npm run build:agent-delta && npm run build:agent-sigma",
    "build:nifty-ticker": "esbuild src/nifty-straddle-ticker.ts --platform=node --target=node20 --bundle --outfile=dist/nifty-straddle-ticker.js --format=cjs",
    "build:fargate": "esbuild src/nifty-straddle/fargate-runner.ts --platform=node --target=node20 --bundle --outfile=dist/fargate-runner.js --format=cjs",
    "build:auto-trader": "esbuild src/autonomous-trader.ts --platform=node --target=node20 --bundle --outfile=dist/autonomous-trader.js --format=cjs",
    "build:weekly-digest": "esbuild src/weekly-digest.ts --platform=node --target=node20 --bundle --outfile=dist/weekly-digest.js --format=cjs",
    "build:trial-reminder": "esbuild src/trial-reminder.ts --platform=node --target=node20 --bundle --outfile=dist/trial-reminder.js --format=cjs",
    "build:all": "npm run build:websocket && npm run build:http && npm run build:simulator && npm run build:agents && npm run build:nifty-ticker && npm run build:fargate && npm run build:auto-trader && npm run build:weekly-digest && npm run build:trial-reminder"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.450.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.980.0",
    "@aws-sdk/client-bedrock-runtime": "^3.980.0",
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-ecs": "^3.980.0",
    "@aws-sdk/client-lambda": "^3.980.0",
    "@aws-sdk/client-ses": "^3.993.0",
    "@aws-sdk/client-ssm": "^3.989.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^2.30.0",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^12.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}
